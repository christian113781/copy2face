{
  "manifest_version": 3,
  "name": "Copy2Paste",
  "version": "1.2.0",
  "description": "Drag to select any area of a webpage, like Lightshot. Copies raw text by default, or an image if you choose that mode.",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "action": {
    "default_title": "Copy2Paste \u2014 click for options, or use a shortcut (default Alt+0 text / Alt+Shift+0 image)",
    "default_popup": "popup.html"
  },
  "commands": {
    "toggle-selection-text": {
      "suggested_key": { "default": "Alt+0" },
      "description": "Start Copy2Paste text selection"
    },
    "toggle-selection-image": {
      "suggested_key": { "default": "Alt+Shift+0" },
      "description": "Start Copy2Paste image selection"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
